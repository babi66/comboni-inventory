    ---
import '../styles/global.css';
---

<html lang="en">
<head>
    <meta charset="utf-8" />
    <!-- THE FIX: This line makes it readable on mobile -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Staff Portal | Asset Entry</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
</head>
<body class="bg-[#f8fafc] min-h-screen font-sans text-slate-900">
    
    <!-- SUCCESS TOAST -->
    <div id="toast" class="fixed top-24 right-5 z-[110] transform translate-x-32 opacity-0 pointer-events-none transition-all duration-700">
        <div class="bg-emerald-500 text-white px-6 py-3 md:px-8 md:py-4 rounded-[2rem] shadow-2xl flex items-center gap-4 border border-white/20 backdrop-blur-md">
            <div class="bg-white/20 p-2 rounded-full">
                <svg class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <span class="font-black tracking-widest uppercase text-[9px] md:text-[10px]">Registry Updated</span>
        </div>
    </div>

    <!-- GLASS NAVIGATION -->
    <nav class="fixed top-0 left-0 right-0 z-[100] bg-white/80 backdrop-blur-md border-b border-slate-200 p-4">
        <div class="container mx-auto flex justify-between items-center">
            <div class="flex items-center gap-3">
                <img src="/images/blocks/logo.jfif" alt="Logo" class="w-8 h-8 md:w-10 md:h-10 object-contain" />
                <div class="flex flex-col">
                    <span class="font-black text-slate-800 leading-none text-xs md:text-sm uppercase tracking-tighter">Comboni</span>
                    <span class="text-[9px] md:text-[10px] font-bold text-blue-600 uppercase tracking-widest">Staff Portal</span>
                </div>
            </div>
            <div class="flex items-center gap-1 md:gap-2">
                <a href="/inventory" class="text-[9px] md:text-[10px] font-black text-slate-500 hover:text-blue-600 px-2 md:px-4 py-2 rounded-xl transition-all uppercase tracking-widest">Analytics</a>
                <button id="logout-btn" class="text-[9px] md:text-[10px] font-black text-red-500 px-2 md:px-4 py-2 rounded-xl uppercase tracking-widest">Logout</button>
            </div>
        </div>
    </nav>

    <div class="h-24"></div>

    <main class="container mx-auto max-w-4xl px-4 md:px-6 pb-24">
        
        <div class="text-center mb-8 md:mb-12">
            <span class="text-blue-600 font-black tracking-[0.4em] text-[9px] md:text-[10px] uppercase mb-2 block">Asset Management System</span>
            <h1 class="text-3xl md:text-4xl font-black text-slate-900 tracking-tighter uppercase">Digital <span class="text-blue-600">Registry</span></h1>
        </div>

        <div class="bg-white rounded-[2rem] md:rounded-[3rem] shadow-2xl overflow-hidden border border-slate-100 mb-10 md:mb-20">
            <!-- FORM HEADER -->
            <div class="bg-slate-900 p-8 md:p-12 text-center text-white relative overflow-hidden">
    <h2 id="form-title" class="text-xl md:text-2xl font-black tracking-tight uppercase relative z-10">New Asset Entry</h2>
    <p id="form-subtitle" class="text-slate-400 text-[10px] mt-2 uppercase tracking-[0.3em] font-bold relative z-10">Select location and item details</p>
</div>

            <form id="asset-form" class="p-6 md:p-16 space-y-8 md:space-y-10">
    <!-- Row 1: Location Details -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-10">
        <div class="space-y-3">
            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Location Block</label>
            <select name="block" id="block-select" required class="w-full bg-slate-50 border-2 border-slate-50 rounded-2xl p-4 md:p-5 text-sm font-bold focus:border-blue-500 focus:bg-white outline-none appearance-none">
                <option value="Block 1">Block 1: Administration</option>
                <option value="Block 2">Block 2: Grade 10</option>
                <option value="Block 3">Block 3: Grade 9</option>
                <option value="Block 4">Block 4: Science Labs</option>
                <option value="Block 5">Block 5: ICT & TV Room</option>
                <option value="Block 6">Block 6: Library</option>
                <option value="Block 7">Block 7: Drawing Bldg</option>
                <option value="Block 8">Block 8: Grade 11</option>
                <option value="Block 9">Block 9: Grade 12 & ICT 1</option>
                <option value="Block 10">Block 10: Services</option>
                <option value="Block 11">Block 11: Pedagogy</option>
            </select>
        </div>

        <div class="space-y-3">
            <label id="section-label" class="block text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Section / Room</label>
            <input name="section" type="text" placeholder="e.g. 9A or Office Name" required 
                class="w-full bg-slate-50 border-2 border-slate-50 rounded-2xl p-4 md:p-5 text-sm font-bold focus:border-blue-500 focus:bg-white outline-none transition-all" />
        </div>
    </div>

    <!-- Row 2: Asset Identification (Integrated Item Code & Optional Serial) -->
    <div class="grid grid-cols-1 md:grid-cols-5 gap-6 md:gap-8">
        <div class="space-y-3">
            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Item Code</label>
            <input name="itemCode" type="text" placeholder="CBT-001" required 
                class="w-full bg-slate-50 border-2 border-slate-50 rounded-2xl p-4 md:p-5 text-sm font-bold outline-none focus:border-blue-500 focus:bg-white" />
        </div>
        
        <!-- NEW: Optional Serial Number Field -->
        <div class="space-y-3">
            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Serial S/N</label>
            <input name="serialNumber" type="text" placeholder="Optional" 
                class="w-full bg-slate-50 border-2 border-slate-50 rounded-2xl p-4 md:p-5 text-sm font-bold outline-none focus:border-blue-500 focus:bg-white" />
        </div>

        <div class="md:col-span-2 space-y-3">
            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Item Description</label>
            <input name="description" list="items-list" placeholder="e.g. HP Laptop" required 
                class="w-full bg-slate-50 border-2 border-slate-50 rounded-2xl p-4 md:p-5 text-sm font-bold outline-none focus:border-blue-500 focus:bg-white" />
        </div>

        <div class="space-y-3">
            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Qty</label>
            <input name="quantity" type="number" min="1" value="1" 
                class="w-full bg-slate-900 text-white rounded-2xl p-4 md:p-5 text-sm font-black text-center outline-none" />
        </div>
    </div>

    <!-- Row 3: Condition Selection -->
    <div class="space-y-4">
        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Status Condition</label>
        <div class="grid grid-cols-2 gap-4 md:gap-6">
            <label class="relative cursor-pointer group">
                <input type="radio" name="condition" value="Functional" checked class="peer sr-only">
                <div class="p-4 md:p-6 text-center rounded-[1.5rem] md:rounded-[2rem] border-2 border-slate-100 bg-white peer-checked:border-emerald-500 peer-checked:bg-emerald-50 peer-checked:text-emerald-700 transition-all font-black text-[10px] uppercase tracking-widest">
                    Functional
                </div>
            </label>
            <label class="relative cursor-pointer group">
                <input type="radio" name="condition" value="Non-Functional" class="peer sr-only">
                <div class="p-4 md:p-6 text-center rounded-[1.5rem] md:rounded-[2rem] border-2 border-slate-100 bg-white peer-checked:border-red-500 peer-checked:bg-red-50 peer-checked:text-red-700 transition-all font-black text-[10px] uppercase tracking-widest">
                    Non-Functional
                </div>
            </label>
        </div>
    </div>

    <!-- Row 4: Action Button -->
    <button type="submit" class="w-full bg-blue-600 text-white font-black py-5 md:py-6 rounded-[1.5rem] md:rounded-[2rem] hover:bg-blue-700 transition-all shadow-xl uppercase tracking-[0.2em] md:tracking-[0.3em] text-[10px] md:text-xs flex items-center justify-center gap-3">
        <span>Submit to Registry</span>
    </button>
</form>
        </div>

        <!-- ACTIVITY LOG -->
        <div class="mt-12 md:mt-20">
            <div class="flex items-center gap-6 mb-8 md:mb-10">
                <h2 class="text-[10px] font-black text-slate-400 uppercase tracking-[0.5em] whitespace-nowrap">Session Logs</h2>
                <div class="h-px bg-slate-200 w-full"></div>
            </div>
            <div id="recent-list" class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
                <!-- JS CONTENT -->
            </div>
        </div>
    </main>

    <!-- FOOTER (Simplified for Mobile) -->



   <footer class="mt-20 pb-10 border-t border-slate-200/50">

        <div class="container mx-auto px-6">
            <div class="flex flex-col md:flex-row justify-between items-center gap-8 pt-10">
                
                <!-- System Info -->
                <div class="flex items-center gap-4">
                    <img src="/images/blocks/logo.jfif" alt="Logo" class="w-8 h-8 grayscale opacity-50" />
                    <div class="flex flex-col items-center md:items-start text-center md:text-left">
                        <span class="text-[10px] font-black text-slate-400 uppercase tracking-[0.1em] md:tracking-[0.2em]">Comboni Inventory Management</span>
                        <span class="text-[9px] font-medium text-slate-400 italic">Official 2018 E.C. Ledger System</span>
                    </div>
                </div>

                <!-- Developer Credit -->
                <div class="flex flex-col items-center md:items-end">
                    <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-2">Architected & Developed by</span>
                    <a href="https://my-portfolio-two-wine-86.vercel.app/" 
                       target="_blank" 
                       rel="noopener noreferrer"
                       class="group flex items-center gap-2 bg-slate-900 text-white px-5 py-2.5 rounded-2xl hover:bg-blue-600 transition-all duration-300 shadow-lg shadow-slate-200">
                        <span class="text-[10px] font-black uppercase tracking-widest">View Portfolio</span>
                        <svg class="w-3 h-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                        </svg>
                    </a>
                </div>

            </div>

            <!-- Bottom Bar -->
            <div class="mt-10 pt-6 border-t border-slate-100 flex justify-center text-center">
                <p class="text-[8px] font-bold text-slate-300 uppercase tracking-[0.3em] md:tracking-[0.5em]">
                    &copy; 2026 Comboni Schools &bull; All Rights Reserved
                </p>
            </div>
        </div>
    </footer>

    <datalist id="items-list">
        <option value="Student Chair"><option value="Student Table">
        <option value="Teacher Table"><option value="Desktop PC">
        <option value="Projector"><option value="Armchair">
    </datalist>

    <script>
    import { db, auth } from '../lib/firebase';
    import { 
        collection, addDoc, serverTimestamp, onSnapshot, 
        query, orderBy, limit, deleteDoc, doc, getDoc, updateDoc 
    } from "firebase/firestore";
    import { onAuthStateChanged, signOut } from "firebase/auth";

    const assetForm = document.getElementById('asset-form');
    const blockSelect = document.getElementById('block-select');
    const sectionLabel = document.getElementById('section-label');
    const toast = document.getElementById('toast');
    const submitBtn = assetForm.querySelector('button[type="submit"]');
    const formTitle = document.getElementById('form-title');
    const formSubtitle = document.getElementById('form-subtitle');

    // NEW: Variable to track if we are editing
    let editId = new URLSearchParams(window.location.search).get('edit');

    // 1. DYNAMIC LABELING
    blockSelect.addEventListener('change', (e) => {
        sectionLabel.innerText = e.target.value === "Block 1" ? "Office / Area Name" : "Section / Room";
    });

    // --- NEW: EDIT MODE INITIALIZATION ---
    if (editId) {
        formTitle.innerText = "Edit Asset Info";
        formSubtitle.innerText = "Modifying registered ledger entry";
        submitBtn.querySelector('span').innerText = "Update Registry Entry";
        submitBtn.classList.replace('bg-blue-600', 'bg-amber-600');

        // Fetch existing data
        getDoc(doc(db, "assets", editId)).then((snap) => {
            if (snap.exists()) {
                const data = snap.data();
                assetForm.block.value = data.block;
                assetForm.section.value = data.section;
                assetForm.itemCode.value = data.itemCode;
                assetForm.serialNumber.value = data.serialNumber || "";
                assetForm.description.value = data.description;
                assetForm.quantity.value = data.quantity;
                // Radio handling
                assetForm.querySelector(`input[name="condition"][value="${data.condition}"]`).checked = true;
            }
        });
    }

    // 2. SECURE DATA SUBMISSION (Modified for Update)
    assetForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(assetForm);
        
        submitBtn.disabled = true;
        submitBtn.classList.add('opacity-50', 'cursor-not-allowed');

        const assetData = {
            itemCode: formData.get('itemCode'),
            block: formData.get('block'),
            serialNumber: formData.get('serialNumber') || "",
            section: formData.get('section'),
            description: formData.get('description'),
            quantity: Number(formData.get('quantity')),
            condition: formData.get('condition'),
            updatedAt: serverTimestamp()
        };

        try {
            if (editId) {
                // UPDATE MODE
                await updateDoc(doc(db, "assets", editId), assetData);
                window.location.href = "/inventory"; // Return to analytics after edit
            } else {
                // CREATE MODE
                await addDoc(collection(db, "assets"), { ...assetData, createdAt: serverTimestamp() });
                
                toast.classList.remove('translate-x-32', 'opacity-0', 'pointer-events-none');
                setTimeout(() => toast.classList.add('translate-x-32', 'opacity-0', 'pointer-events-none'), 3000);
                assetForm.reset();
                sectionLabel.innerText = "Section / Room";
            }
        } catch (err) { 
            console.error(err);
            alert("Error updating cloud ledger."); 
        } finally {
            submitBtn.disabled = false;
            submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        }
    });

    // 3. REAL-TIME LOGS (Remains mostly same)
    const q = query(collection(db, "assets"), orderBy("createdAt", "desc"), limit(10));
    
    onSnapshot(q, (snapshot) => {
        const list = document.getElementById('recent-list');
        list.innerHTML = snapshot.docs.map(snap => {
            const data = snap.data();
            const isFunctional = data.condition === 'Functional';
            const serialBadge = data.serialNumber 
                ? `<span class="text-[8px] font-black bg-amber-50 text-amber-600 px-2.5 py-1 rounded-lg border border-amber-100 uppercase tracking-tighter">S/N: ${data.serialNumber}</span>` 
                : '';

            return `
            <div class="bg-white p-6 md:p-8 rounded-[2.5rem] shadow-sm border border-slate-100 flex justify-between items-center group hover:shadow-xl hover:border-blue-100 transition-all duration-300">
                <div class="space-y-3">
                    <div class="flex items-center gap-2 flex-wrap">
                        <span class="text-[8px] font-black bg-slate-900 text-white px-2.5 py-1 rounded-lg uppercase tracking-tighter">${data.itemCode || 'NO CODE'}</span>
                        ${serialBadge}
                        <span class="text-[8px] font-black bg-blue-50 text-blue-600 px-2.5 py-1 rounded-lg uppercase tracking-tighter">${data.block}</span>
                    </div>
                    <div>
                        <p class="text-sm font-black text-slate-800 leading-tight">${data.quantity}x ${data.description}</p>
                        <div class="flex items-center gap-1.5 mt-1">
                            <div class="w-1.5 h-1.5 rounded-full ${isFunctional ? 'bg-emerald-500' : 'bg-red-500'}"></div>
                            <p class="text-[9px] font-black ${isFunctional ? 'text-emerald-600' : 'text-red-600'} uppercase tracking-widest">${data.condition}</p>
                        </div>
                    </div>
                </div>
                <div class="flex flex-col gap-2 opacity-0 group-hover:opacity-100 transition-all">
                    <a href="/?edit=${snap.id}" class="p-2 text-slate-300 hover:text-blue-500 hover:bg-blue-50 rounded-xl transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                    </a>
                    <button data-id="${snap.id}" class="delete-trigger p-2 text-slate-300 hover:text-red-500 hover:bg-red-50 rounded-xl transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                    </button>
                </div>
            </div>
            `;
        }).join('');

        document.querySelectorAll('.delete-trigger').forEach(btn => {
            btn.onclick = async () => {
                const id = btn.getAttribute('data-id');
                if (confirm("Remove this entry from the registry?")) {
                    await deleteDoc(doc(db, "assets", id));
                }
            };
        });
    });

    onAuthStateChanged(auth, (user) => { if (!user) window.location.href = "/login"; });
    document.getElementById('logout-btn').addEventListener('click', () => signOut(auth));
</script>
</body>
</html>
