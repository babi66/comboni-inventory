---
import '../styles/global.css';
---

<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Comboni Executive Analytics</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
</head>
<body class="bg-slate-50 text-slate-900 font-sans leading-relaxed overflow-x-hidden">
    
    <!-- GLASS NAVIGATION -->
    <nav class="fixed top-0 left-0 right-0 z-[100] bg-white/10 backdrop-blur-md border-b border-white/20 p-3 md:p-4">
        <div class="container mx-auto flex justify-between items-center">
            <div class="flex items-center gap-2 md:gap-3">
                <img src="/images/blocks/logo.jfif" alt="Logo" class="w-8 h-8 md:w-10 md:h-10 object-contain drop-shadow-md" />
                <div class="flex flex-col">
                    <span class="font-black text-white leading-none text-xs md:text-sm uppercase tracking-tighter">Comboni</span>
                    <span class="text-[8px] md:text-[10px] font-bold text-blue-300 uppercase tracking-widest">Analytics Portal</span>
                </div>
            </div>
            <div class="flex items-center gap-1 md:gap-2">
                <a href="/" class="text-[8px] md:text-[10px] font-black text-white/80 hover:text-white px-2 py-2 rounded-xl uppercase tracking-widest">Register</a>
                <div class="w-px h-4 bg-white/20 mx-1 md:mx-2"></div>
                <button id="logout-btn" class="text-[8px] md:text-[10px] font-black text-red-400 hover:bg-red-500 hover:text-white px-3 py-2 rounded-xl uppercase tracking-widest">Logout</button>
            </div>
        </div>
    </nav>

    <!-- HERO SECTION -->
    <header class="relative h-[400px] md:h-[500px] bg-blue-950 flex items-center justify-center text-center px-4 overflow-hidden">
        <img src="/images/blocks/block1.jpg" 
             class="absolute inset-0 w-full h-full object-cover opacity-30" />
        
        <div class="absolute inset-0 bg-gradient-to-t from-slate-50 via-blue-950/60 to-transparent"></div>
        
        <div class="relative z-10 flex flex-col items-center mt-12 md:mt-16">
            <span class="text-blue-300 font-black tracking-[0.3em] md:tracking-[0.5em] text-[8px] md:text-[10px] uppercase mb-4 block drop-shadow-md">
                Official 2018 E.C. Ledger
            </span>
            <h1 class="text-4xl md:text-7xl font-black text-white mb-2 drop-shadow-2xl tracking-tighter uppercase">
                Inventory <span class="text-blue-400">Control</span>
            </h1>
            <p class="text-blue-100 text-xs md:text-sm font-medium max-w-2xl mx-auto italic opacity-90 uppercase tracking-[0.1em] md:tracking-[0.2em]">
                "Visualizing every asset, Block by Block"
            </p>
        </div>
    </header>

    <!-- MAIN CONTENT -->
   <main class="container mx-auto px-4 md:px-6 relative z-20 -mt-12 md:mt-16">
    
    <!-- Global Stat Cards -->
    <div class="grid grid-cols-2 lg:grid-cols-6 gap-3 md:gap-4 mb-10 md:mb-16">
        
        <!-- Total Assets -->
        <div class="bg-white p-4 md:p-6 rounded-2xl md:rounded-[2rem] shadow-xl border-b-4 border-blue-600 hover:-translate-y-1 transition-all duration-300 group">
            <p class="text-[8px] font-black text-slate-400 uppercase tracking-widest mb-1 group-hover:text-blue-600">Total Assets</p>
            <h2 id="grand-total" class="text-2xl md:text-3xl font-black text-slate-800 tracking-tighter">0</h2>
        </div>
        
        <!-- Functional -->
        <div class="bg-white p-4 md:p-6 rounded-2xl md:rounded-[2rem] shadow-xl border-b-4 border-emerald-500 hover:-translate-y-1 transition-all duration-300 group">
            <p class="text-[8px] font-black text-slate-400 uppercase tracking-widest mb-1 group-hover:text-emerald-500">Functional</p>
            <h2 id="func-total" class="text-2xl md:text-3xl font-black text-emerald-600 tracking-tighter">0</h2>
        </div>

        <!-- Maintenance -->
        <div class="bg-white p-4 md:p-6 rounded-2xl md:rounded-[2rem] shadow-xl border-b-4 border-red-500 hover:-translate-y-1 transition-all duration-300 group">
            <p class="text-[8px] font-black text-slate-400 uppercase tracking-widest mb-1 group-hover:text-red-500">Non Functional</p>
            <h2 id="non-func-total" class="text-2xl md:text-3xl font-black text-red-600 tracking-tighter">0</h2>
        </div>

        <!-- Chairs -->
        <div class="bg-white p-4 md:p-6 rounded-2xl md:rounded-[2rem] shadow-xl border-b-4 border-blue-400 hover:-translate-y-1 transition-all duration-300 group">
            <p class="text-[8px] font-black text-slate-400 uppercase tracking-widest mb-1 group-hover:text-blue-400">Chairs</p>
            <h2 id="chairs-total" class="text-2xl md:text-3xl font-black text-slate-800 tracking-tighter">0</h2>
        </div>

        <!-- Tables -->
        <div class="bg-white p-4 md:p-6 rounded-2xl md:rounded-[2rem] shadow-xl border-b-4 border-blue-400 hover:-translate-y-1 transition-all duration-300 group">
            <p class="text-[8px] font-black text-slate-400 uppercase tracking-widest mb-1 group-hover:text-blue-400">Tables</p>
            <h2 id="tables-total" class="text-2xl md:text-3xl font-black text-slate-800 tracking-tighter">0</h2>
        </div>

        <!-- Computers -->
        <div class="bg-white p-4 md:p-6 rounded-2xl md:rounded-[2rem] shadow-xl border-b-4 border-blue-400 hover:-translate-y-1 transition-all duration-300 group">
            <p class="text-[8px] font-black text-slate-400 uppercase tracking-widest mb-1 group-hover:text-blue-400">Computers</p>
            <h2 id="pcs-total" class="text-2xl md:text-3xl font-black text-slate-800 tracking-tighter">0</h2>
        </div>

        <!-- EXPORT BUTTON -->
        <!-- col-span-2 on mobile (Full Width) | lg:col-span-2 on desktop (Compact) -->
        <button id="export-btn" class="col-span-2 lg:col-span-2 lg:col-start-5 group bg-slate-900 text-white p-5 rounded-2xl md:rounded-[2rem] shadow-xl hover:bg-blue-600 hover:-translate-y-1 transition-all duration-300 flex justify-center items-center gap-3 mt-4">
            <div class="text-center lg:text-left">
                <span class="block text-[7px] font-black uppercase opacity-60 tracking-widest">2018 E.C. Ledger</span>
                <span class="text-xs font-extrabold uppercase tracking-tighter">Export Excel</span>
            </div>
            <svg class="w-5 h-5 opacity-50 group-hover:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
        </button>
    </div>

    <div id="block-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-10">
        <!-- JS Injected Content -->
    </div>
</main>
    <!-- SYSTEM FOOTER -->
    <footer class="mt-20 pb-10 border-t border-slate-200/50">
        <div class="container mx-auto px-6">
            <div class="flex flex-col md:flex-row justify-between items-center gap-8 pt-10">
                
                <!-- System Info -->
                <div class="flex items-center gap-4">
                    <img src="/images/blocks/logo.jfif" alt="Logo" class="w-8 h-8 grayscale opacity-50" />
                    <div class="flex flex-col items-center md:items-start text-center md:text-left">
                        <span class="text-[10px] font-black text-slate-400 uppercase tracking-[0.1em] md:tracking-[0.2em]">Comboni Inventory Management</span>
                        <span class="text-[9px] font-medium text-slate-400 italic">Official 2018 E.C. Ledger System</span>
                    </div>
                </div>

                <!-- Developer Credit -->
                <div class="flex flex-col items-center md:items-end">
                    <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-2">Architected & Developed by</span>
                    <a href="https://my-portfolio-two-wine-86.vercel.app/" 
                       target="_blank" 
                       rel="noopener noreferrer"
                       class="group flex items-center gap-2 bg-slate-900 text-white px-5 py-2.5 rounded-2xl hover:bg-blue-600 transition-all duration-300 shadow-lg shadow-slate-200">
                        <span class="text-[10px] font-black uppercase tracking-widest">View Portfolio</span>
                        <svg class="w-3 h-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                        </svg>
                    </a>
                </div>

            </div>

            <!-- Bottom Bar -->
            <div class="mt-10 pt-6 border-t border-slate-100 flex justify-center text-center">
                <p class="text-[8px] font-bold text-slate-300 uppercase tracking-[0.3em] md:tracking-[0.5em]">
                    &copy; 2026 Comboni Schools &bull; All Rights Reserved
                </p>
            </div>
        </div>
    </footer>

    <script>
        import { db, auth } from '../lib/firebase';
        import { collection, onSnapshot } from "firebase/firestore";
        import { signOut, onAuthStateChanged } from "firebase/auth";
        import * as XLSX from 'xlsx';

        let currentAssets = [];

        onAuthStateChanged(auth, (user) => { if (!user) window.location.href = "/login"; });
        document.getElementById('logout-btn')?.addEventListener('click', () => {
            signOut(auth).then(() => window.location.href = "/login");
        });

        const blockDetails = [
            { id: 1, label: "Administration", info: "Offices & WC", img: "/images/blocks/block1.jpg" },
            { id: 2, label: "Grade 10", info: "Classrooms", img: "/images/blocks/block2.jpg" },
            { id: 3, label: "Grade 9", info: "Classrooms", img: "/images/blocks/block3.jpg" },
            { id: 4, label: "Science Labs", info: "Chem, Bio, Physics", img: "/images/blocks/block4.jpg" },
            { id: 5, label: "ICT & TV Room", info: "Tech Center", img: "/images/blocks/block5.jpg" },
            { id: 6, label: "Library", info: "Study Areas", img: "/images/blocks/block6.jpg" },
            { id: 7, label: "Drawing Bldg", info: "Technical Art", img: "/images/blocks/block7.jpg" },
            { id: 8, label: "Grade 11", info: "Classrooms", img: "/images/blocks/block8.jpg" },
            { id: 9, label: "Grade 12 & ICT 1", info: "Offices & CTE", img: "/images/blocks/block9.jpg" },
            { id: 10, label: "Services", info: "Restrooms", img: "/images/blocks/block10.jpg" },
            { id: 11, label: "Pedagogy", info: "Training Center", img: "/images/blocks/block11.jpg" }
        ];

        onSnapshot(collection(db, "assets"), (snapshot) => {
    currentAssets = snapshot.docs.map(doc => doc.data());
    
    // 1. Logic for Totals and Conditions
    const total = currentAssets.reduce((s, a) => s + Number(a.quantity || 0), 0);
    const functional = currentAssets.filter(a => a.condition === 'Functional').reduce((s, a) => s + Number(a.quantity || 0), 0);
    
    // NEW: Calculate Non-Functional items for maintenance tracking
    const nonFunctional = currentAssets.filter(a => a.condition === 'Non-Functional').reduce((s, a) => s + Number(a.quantity || 0), 0);

    // 2. Logic for Specific Item Categories
    const chairs = currentAssets.filter(a => a.description.toLowerCase().includes('chair')).reduce((s, a) => s + Number(a.quantity || 0), 0);
    const tables = currentAssets.filter(a => a.description.toLowerCase().includes('table')).reduce((s, a) => s + Number(a.quantity || 0), 0);
    const pcs = currentAssets.filter(a => a.description.toLowerCase().includes('pc') || a.description.toLowerCase().includes('computer')).reduce((s, a) => s + Number(a.quantity || 0), 0);

    // 3. Update the UI text elements
    document.getElementById('grand-total').innerText = total;
    document.getElementById('func-total').innerText = functional;
    document.getElementById('non-func-total').innerText = nonFunctional; // NEW
    document.getElementById('chairs-total').innerText = chairs;
    document.getElementById('tables-total').innerText = tables;
    document.getElementById('pcs-total').innerText = pcs;

    // 4. Render Block Cards
    const container = document.getElementById('block-container');
    container.innerHTML = blockDetails.map(block => {
        const blockAssets = currentAssets.filter(a => a.block === `Block ${block.id}`);
        const count = blockAssets.reduce((s, a) => s + Number(a.quantity || 0), 0);
        return `
        <div class="bg-white rounded-[2rem] shadow-lg border border-slate-200 overflow-hidden hover:shadow-2xl transition-all group">
            <div class="h-44 relative">
                <img src="${block.img}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 to-transparent"></div>
                <div class="absolute bottom-4 left-4 text-white">
                    <span class="text-[10px] font-bold uppercase tracking-widest opacity-80">Block ${block.id}</span>
                    <h3 class="text-xl font-bold uppercase tracking-tighter">${block.label}</h3>
                </div>
            </div>
            <div class="p-6">
                <div class="flex justify-between items-center mb-4">
                    <span class="text-xs text-slate-500 font-bold uppercase">${block.info}</span>
                    <span class="bg-blue-50 text-blue-700 px-3 py-1 rounded-full text-[10px] font-black">${count} ITEMS</span>
                </div>
                <details class="group/det">
                    <summary class="list-none cursor-pointer text-blue-600 font-black text-[10px] flex items-center gap-1 group-open/det:mb-4 uppercase tracking-widest">
                        <svg class="w-3 h-3 transition-transform group-open/det:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M19 9l-7 7-7-7"></path></svg>
                        Details
                    </summary>
                    <div class="space-y-2 max-h-60 overflow-y-auto pr-2">
                        ${generateSections(blockAssets)}
                    </div>
                </details>
            </div>
        </div>
        `;
    }).join('');
});

        function generateSections(assets) {
    const groups = {};
    assets.forEach(a => {
        const sec = a.section || "General";
        if (!groups[sec]) groups[sec] = [];
        groups[sec].push(a);
    });

    return Object.entries(groups).map(([sec, items]) => `
        <div class="bg-slate-50 p-3 rounded-2xl border border-slate-100">
            <div class="flex justify-between items-center mb-2">
                <span class="font-black text-slate-700 text-[9px] uppercase tracking-tighter">Section ${sec}</span>
                <span class="text-[8px] font-black bg-white px-2 py-0.5 rounded shadow-sm text-slate-500 border border-slate-200">
                    ${items.reduce((s, i) => s + Number(i.quantity || 0), 0)} Qty
                </span>
            </div>
            <div class="text-[10px] text-slate-500 leading-tight space-y-1">
                ${items.map(i => `
    <div class="flex flex-col gap-0.5 border-b border-slate-200/50 pb-1 last:border-0 last:pb-0">
        <div class="flex gap-1 items-center">
            <span class="font-bold text-blue-600 shrink-0">[${i.itemCode || 'N/A'}]</span>
            <span>${i.quantity}x ${i.description}</span>
        </div>
        <!-- Only show S/N if it exists in the database -->
        ${i.serialNumber ? `
            <div class="text-[8px] font-bold text-amber-600 bg-amber-50 px-1.5 py-0.5 rounded w-fit ml-1">
                S/N: ${i.serialNumber}
            </div>
        ` : ''}
    </div>
`).join('')}
            </div>
        </div>
    `).join('');
}

        document.getElementById('export-btn')?.addEventListener('click', () => {
    if (currentAssets.length === 0) return alert("No data to export!");

    // 1. Main Heading
    const title = [["COMBONI SCHOOL FIXED ASSETS 2018 E.C"]];
    
    // 2. Metadata Heading
    const date = [["Report Date: " + new Date().toLocaleDateString()]];
    
    // 3. Spacing Row
    const empty = [[]];
    
    // 4. SUB-HEADINGS (Added "Serial S/N")
    const columnHeadings = [["Item Code", "Serial S/N", "Block", "Section/Room", "Item Description", "Quantity", "Condition"]];
    
    // 5. Data Rows (Added d.serialNumber)
    const rows = currentAssets.map(d => [
        d.itemCode || "N/A",
        d.serialNumber || "N/A", // New Column for Serial Numbers
        d.block || "N/A", 
        d.section || "General", 
        d.description || "Unnamed Item", 
        d.quantity || 0, 
        d.condition || "N/A"
    ]);

    // Combine everything
    const finalData = [
        ...title, 
        ...date, 
        ...empty, 
        ...columnHeadings, 
        ...rows
    ];

    // Create Worksheet
    const ws = XLSX.utils.aoa_to_sheet(finalData);

    // Centering the Main Heading (Updated merge to span 7 columns: A1 to G1)
    ws["!merges"] = [
        { s: { r: 0, c: 0 }, e: { r: 0, c: 6 } } 
    ];

    // Set Column Widths (Updated for the new 7-column layout)
    ws["!cols"] = [
        { wch: 15 }, // Item Code
        { wch: 20 }, // Serial S/N (wider for hardware IDs)
        { wch: 15 }, // Block
        { wch: 20 }, // Section
        { wch: 40 }, // Description
        { wch: 10 }, // Quantity
        { wch: 15 }  // Condition
    ];

    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, "Assets_2018_EC");

    // Save File
    XLSX.writeFile(wb, "Comboni_Fixed_Assets_2018EC.xlsx");
});
    </script>
</body>
</html>